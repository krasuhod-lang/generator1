# SEO Genius v4.0 — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Либо DATABASE_URL, либо отдельные переменные
DATABASE_URL=postgresql://seogenius:your_password@localhost:5432/seogenius_db
# Или отдельно:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=seogenius_db
# DB_USER=seogenius
# DB_PASSWORD=your_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Или отдельно:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
# Модель DeepSeek (по умолчанию deepseek-chat)
# Для R1 (reasoning) модели: deepseek-reasoner или deepseek-r1
# При использовании R1: system prompt автоматически переносится в user prompt
DEEPSEEK_MODEL=deepseek-chat
# ⚠ GEMINI_API_KEY — ОБЯЗАТЕЛЬНО. Без него не работают: SEO-генератор контента
# (Stage 3/5/6), AI-редактор и генератор мета-тегов. В исходниках ключ НЕ хранится
# (Google Secret Scanning отзывает публично доступные ключи), поэтому задайте его
# здесь, в .env (этот файл в .gitignore и в репозиторий не попадает).
GEMINI_API_KEY=your_gemini_api_key
# Модель Gemini (по умолчанию gemini-3.1-pro-preview)
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Grok (x.ai) — альтернативный провайдер для Stage 3/5/6, AI-редактора и мета-тегов ─
# Активируется, когда задача создаётся с llm_provider=grok (см. селектор в UI).
# По умолчанию используется reasoning-модель grok-4.20-0309-reasoning.
# ⚠ Reasoning-модели x.ai НЕ поддерживают response_format=json_object — JSON-strict
#   гарантируется только инструкцией в system-промпте. Адаптер это знает
#   (см. _isReasoningModel в backend/src/services/llm/grok.adapter.js) и
#   автоматически отключает json_object для имён, содержащих «reasoning» / «thinking» / «-r1».
# ⚠ Если у вашего ключа нет доступа к этой модели — поменяйте на grok-4 / grok-4-fast.
#   Список доступных моделей покажет: docker exec seo_worker node scripts/check-proxy.js
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-4.20-0309-reasoning
# XAI_BASE_URL=https://api.x.ai/v1   # необязательно, по умолчанию официальный endpoint

# ── Proxy (ОБЯЗАТЕЛЬНО для Gemini И Grok из России) ───────────────────────
#
# ⚠ ВАЖНО: достаточно настроить ОДИН прокси на оба провайдера.
#   Адаптер Grok сам подхватит GEMINI_PROXY_* (или общие LLM_PROXY_*),
#   если отдельные XAI_PROXY_* не заданы. Порядок резолвинга:
#     1) XAI_PROXY_*   (только если хотите разный прокси для x.ai)
#     2) LLM_PROXY_*   (общий канал для всех LLM — рекомендуется)
#     3) GEMINI_PROXY_* (fallback — тот же прокси, что и для Gemini)
#     4) HTTPS_PROXY    (системный)
#   Без прокси оба адаптера бросают ошибку на старте запроса (никаких «прямых» вызовов).
#
#
# ⚠ БЕЗ ПРОКСИ GEMINI API НЕ БУДЕТ РАБОТАТЬ!
#
# ─── Рекомендуемый способ (компоненты — работает всегда): ─────────────────
# Используйте отдельные переменные — они не ломаются от спецсимволов в пароле.
#
GEMINI_PROXY_HOST=your_proxy_ip
GEMINI_PROXY_PORT=your_proxy_port
GEMINI_PROXY_USER=your_proxy_login
GEMINI_PROXY_PASS=your_proxy_password
# GEMINI_PROXY_PROTO=http
#
# ─── Альтернатива (полная строка — требует правильное экранирование): ─────
# ⚠ Если в пароле есть спецсимволы (#, $, @, !, пробелы) — обязательно
#    оберните ВСЮ строку в двойные кавычки:
#
# GEMINI_PROXY_URL="http://login:password@ip:port"
#
# Также поддерживаются форматы провайдеров (авто-конвертация):
# GEMINI_PROXY_URL="login:password:ip:port"
# GEMINI_PROXY_URL="http://login:password:ip:port"
#
# ─── Запасной прокси (авто-переключение при гео-блокировке): ──────────────
# GEMINI_PROXY_HOST_2=backup_proxy_ip
# GEMINI_PROXY_PORT_2=backup_proxy_port
# GEMINI_PROXY_USER_2=backup_proxy_login
# GEMINI_PROXY_PASS_2=backup_proxy_password
#
# ─── Прокси для Grok (x.ai) ──────────────────────────────────────────────
# Приоритет резолвинга в grok.adapter.js:
#   1) XAI_PROXY_*   — специфично для Grok
#   2) LLM_PROXY_*   — общий для всех LLM (рекомендуется при одном провайдере прокси)
#   3) GEMINI_PROXY_* — fallback (тот же канал, что у Gemini)
#   4) HTTPS_PROXY    — системный
# Без прокси grok.adapter бросит ошибку (как и Gemini).
#
# XAI_PROXY_HOST=your_proxy_ip
# XAI_PROXY_PORT=your_proxy_port
# XAI_PROXY_USER=your_proxy_login
# XAI_PROXY_PASS=your_proxy_password
# XAI_PROXY_URL="http://login:password@ip:port"   # альтернатива
#
# ─── Общий LLM_PROXY_* (если хотите один источник на всех провайдеров) ───
# LLM_PROXY_HOST=your_proxy_ip
# LLM_PROXY_PORT=your_proxy_port
# LLM_PROXY_USER=your_proxy_login
# LLM_PROXY_PASS=your_proxy_password
#
# ─── Проверка прокси из контейнера: ──────────────────────────────────────
#   docker exec seo_worker node scripts/check-proxy.js
# ─────────────────────────────────────────────────────────────────────────

# ── Rate limits (можно переопределить, дефолты работают для прода) ────────
# AUTH_LOGIN_RATE_LIMIT=10        # попыток логина за 15 мин на IP (skip успешных)
# AUTH_REGISTER_RATE_LIMIT=5      # регистраций за 1 час на IP
#  /api/tasks/:id/logs — 120/мин per-IP (захардкожен; влияет только на админ-страницы
#  и переподключения к мониторингу — фронт читает /logs один раз при mount).

# ── Redis-кэш ответа LLM (опционально) ─────────────────────────────────────
# Детерминированный кэш по ключу sha256(adapter+model+system+user+temperature+maxTokens).
# Помогает, когда юзер пересоздаёт ту же задачу с теми же входами — экономит деньги.
# LLM_RESPONSE_CACHE_ENABLED=false
# LLM_RESPONSE_CACHE_TTL_SECONDS=604800   # 7 дней по умолчанию

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
# ⚠ JWT_SECRET — ОБЯЗАТЕЛЬНО задайте уникальное значение!
# Если не задан, система будет работать со встроенным fallback-секретом,
# но для безопасности в продакшне рекомендуется задать свой.
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Docker Compose ────────────────────────────────────────────────────────
# ⚠ ВАЖНО: POSTGRES_USER и POSTGRES_DB используются как для создания БД,
#   так и для формирования DATABASE_URL внутри docker-compose.yml.
#   Если вы меняете эти значения ПОСЛЕ первого запуска, нужно удалить
#   volume базы данных: docker compose down -v && docker compose up -d --build
#   Иначе PostgreSQL выдаст ошибку: Role "..." does not exist.
POSTGRES_DB=seogenius_db
POSTGRES_USER=seogenius
POSTGRES_PASSWORD=your_password

# ── Admin Panel ────────────────────────────────────────────────────────────
# Администратор создаётся/обновляется автоматически при каждом запуске.
# Если вы измените email или пароль — просто перезапустите сервер.
# По умолчанию (если не задано): targetlid1@yandex.ru / 1324354657Cfif
ADMIN_EMAIL=targetlid1@yandex.ru
ADMIN_PASSWORD=1324354657Cfif