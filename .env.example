# SEO Genius v4.0 — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Либо DATABASE_URL, либо отдельные переменные
DATABASE_URL=postgresql://seogenius:your_password@localhost:5432/seogenius_db
# Или отдельно:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=seogenius_db
# DB_USER=seogenius
# DB_PASSWORD=your_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Или отдельно:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY зашифрован в коде (не требуется)
# GEMINI_API_KEY зашифрован в коде (не требуется)

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Docker Compose ────────────────────────────────────────────────────────
POSTGRES_DB=seogenius_db
POSTGRES_USER=seogenius
POSTGRES_PASSWORD=your_password