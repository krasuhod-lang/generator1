# SEO Genius v4.0 — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Либо DATABASE_URL, либо отдельные переменные
DATABASE_URL=postgresql://seogenius:your_password@localhost:5432/seogenius_db
# Или отдельно:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=seogenius_db
# DB_USER=seogenius
# DB_PASSWORD=your_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Или отдельно:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
GEMINI_API_KEY=your_gemini_api_key
# Модель Gemini (по умолчанию gemini-3.1-pro-preview)
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Proxy (опционально, для Gemini API из ограниченных регионов) ──────────
# Вариант 1: полная строка
# GEMINI_PROXY_URL=http://login:password@ip:port
#
# Вариант 2: отдельные компоненты (удобнее менять)
GEMINI_PROXY_HOST=your_proxy_host
GEMINI_PROXY_PORT=your_proxy_port
GEMINI_PROXY_USER=your_proxy_user
GEMINI_PROXY_PASS=your_proxy_pass
# GEMINI_PROXY_PROTO=http
#
# Запасной прокси (автоматически переключается при гео-блокировке)
# GEMINI_PROXY_URL_2=http://login:password@ip2:port2
# Или компонентами:
# GEMINI_PROXY_HOST_2=your_backup_proxy_host
# GEMINI_PROXY_PORT_2=your_backup_proxy_port
# GEMINI_PROXY_USER_2=your_backup_proxy_user
# GEMINI_PROXY_PASS_2=your_backup_proxy_pass

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Docker Compose ────────────────────────────────────────────────────────
POSTGRES_DB=seogenius_db
POSTGRES_USER=seogenius
POSTGRES_PASSWORD=your_password