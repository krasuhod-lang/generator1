# SEO Genius v4.0 — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Либо DATABASE_URL, либо отдельные переменные
DATABASE_URL=postgresql://seogenius:your_password@localhost:5432/seogenius_db
# Или отдельно:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=seogenius_db
# DB_USER=seogenius
# DB_PASSWORD=your_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Или отдельно:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
# Модель DeepSeek (по умолчанию deepseek-chat)
# Для R1 (reasoning) модели: deepseek-reasoner или deepseek-r1
# При использовании R1: system prompt автоматически переносится в user prompt
DEEPSEEK_MODEL=deepseek-chat
# ⚠ GEMINI_API_KEY — ОБЯЗАТЕЛЬНО. Без него не работают: SEO-генератор контента
# (Stage 3/5/6), AI-редактор и генератор мета-тегов. В исходниках ключ НЕ хранится
# (Google Secret Scanning отзывает публично доступные ключи), поэтому задайте его
# здесь, в .env (этот файл в .gitignore и в репозиторий не попадает).
GEMINI_API_KEY=your_gemini_api_key
# Модель Gemini (по умолчанию gemini-3.1-pro-preview)
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Proxy (ОБЯЗАТЕЛЬНО для Gemini API из ограниченных регионов) ───────────
#
# ⚠ БЕЗ ПРОКСИ GEMINI API НЕ БУДЕТ РАБОТАТЬ!
#
# ─── Рекомендуемый способ (компоненты — работает всегда): ─────────────────
# Используйте отдельные переменные — они не ломаются от спецсимволов в пароле.
#
GEMINI_PROXY_HOST=your_proxy_ip
GEMINI_PROXY_PORT=your_proxy_port
GEMINI_PROXY_USER=your_proxy_login
GEMINI_PROXY_PASS=your_proxy_password
# GEMINI_PROXY_PROTO=http
#
# ─── Альтернатива (полная строка — требует правильное экранирование): ─────
# ⚠ Если в пароле есть спецсимволы (#, $, @, !, пробелы) — обязательно
#    оберните ВСЮ строку в двойные кавычки:
#
# GEMINI_PROXY_URL="http://login:password@ip:port"
#
# Также поддерживаются форматы провайдеров (авто-конвертация):
# GEMINI_PROXY_URL="login:password:ip:port"
# GEMINI_PROXY_URL="http://login:password:ip:port"
#
# ─── Запасной прокси (авто-переключение при гео-блокировке): ──────────────
# GEMINI_PROXY_HOST_2=backup_proxy_ip
# GEMINI_PROXY_PORT_2=backup_proxy_port
# GEMINI_PROXY_USER_2=backup_proxy_login
# GEMINI_PROXY_PASS_2=backup_proxy_password
#
# ─── Проверка прокси из контейнера: ──────────────────────────────────────
#   docker exec seo_worker node scripts/check-proxy.js
# ─────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
# ⚠ JWT_SECRET — ОБЯЗАТЕЛЬНО задайте уникальное значение!
# Если не задан, система будет работать со встроенным fallback-секретом,
# но для безопасности в продакшне рекомендуется задать свой.
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Docker Compose ────────────────────────────────────────────────────────
# ⚠ ВАЖНО: POSTGRES_USER и POSTGRES_DB используются как для создания БД,
#   так и для формирования DATABASE_URL внутри docker-compose.yml.
#   Если вы меняете эти значения ПОСЛЕ первого запуска, нужно удалить
#   volume базы данных: docker compose down -v && docker compose up -d --build
#   Иначе PostgreSQL выдаст ошибку: Role "..." does not exist.
POSTGRES_DB=seogenius_db
POSTGRES_USER=seogenius
POSTGRES_PASSWORD=your_password

# ── Admin Panel ────────────────────────────────────────────────────────────
# Администратор создаётся/обновляется автоматически при каждом запуске.
# Если вы измените email или пароль — просто перезапустите сервер.
# По умолчанию (если не задано): targetlid1@yandex.ru / 1324354657Cfif
ADMIN_EMAIL=targetlid1@yandex.ru
ADMIN_PASSWORD=1324354657Cfif