# SEO Genius v4.0 — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Либо DATABASE_URL, либо отдельные переменные
DATABASE_URL=postgresql://seogenius:your_password@localhost:5432/seogenius_db
# Или отдельно:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=seogenius_db
# DB_USER=seogenius
# DB_PASSWORD=your_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Или отдельно:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
# Модель DeepSeek (по умолчанию deepseek-chat)
# Для R1 (reasoning) модели: deepseek-reasoner или deepseek-r1
# При использовании R1: system prompt автоматически переносится в user prompt
DEEPSEEK_MODEL=deepseek-chat
# ⚠ GEMINI_API_KEY — ОБЯЗАТЕЛЬНО. Без него не работают: SEO-генератор контента
# (Stage 3/5/6), AI-редактор и генератор мета-тегов. В исходниках ключ НЕ хранится
# (Google Secret Scanning отзывает публично доступные ключи), поэтому задайте его
# здесь, в .env (этот файл в .gitignore и в репозиторий не попадает).
GEMINI_API_KEY=your_gemini_api_key
# Модель Gemini (по умолчанию gemini-3.1-pro-preview)
GEMINI_MODEL=gemini-3.1-pro-preview
# ── Тарифы Gemini для расчёта cost_usd (USD за 1M токенов) ─────────────────
# По умолчанию используются цены gemini-2.5-pro (апрель 2026). Если у вас
# подключена другая модель (gemini-3.x-pro-preview, gemini-2.5-flash и т.д.) —
# переопределите тарифы здесь, чтобы расход в БД соответствовал реальному биллингу.
# Контекст ≤ 200K input-токенов:
# GEMINI_INPUT_PRICE_USD_PER_1M_SHORT=2.0
# GEMINI_OUTPUT_PRICE_USD_PER_1M_SHORT=12.0
# GEMINI_CACHED_INPUT_PRICE_USD_PER_1M_SHORT=0.5
# Контекст > 200K input-токенов (long-context tier):
# GEMINI_INPUT_PRICE_USD_PER_1M_LONG=4.0
# GEMINI_OUTPUT_PRICE_USD_PER_1M_LONG=18.0
# GEMINI_CACHED_INPUT_PRICE_USD_PER_1M_LONG=1.0
#
# ⚠ thoughtsTokens (Gemini 2.5/3.x thinking-модели) и cachedContentTokens
# теперь корректно учитываются: thoughts тарифицируются как output (т.к.
# биллинг Google делает именно так), cached input — по дисконтированному
# тарифу. Старая формула игнорировала оба поля и могла занижать расход
# в 2–5 раз для длинных reasoning-ответов. Новая формула применяется только
# к новым задачам — старые task'и в БД не пересчитываем.
# Таймаут одного HTTP-запроса к Gemini в миллисекундах. Дефолт 300000 (5 мин).
# gemini-3.1-pro-preview — reasoning-модель: writer-стадии (info-article Stage 3,
# link-article writer, главный pipeline Stage 3) с maxTokens=16384 и большим
# IAKB-промптом стабильно отвечают 3–5 минут. Старый дефолт 180000 ронял
# генерацию по timeout. Допустимый диапазон: 1000…600000.
# GEMINI_TIMEOUT_MS=300000

# ── Grok (x.ai) — альтернативный провайдер для Stage 3/5/6, AI-редактора и мета-тегов ─
# Активируется, когда задача создаётся с llm_provider=grok (см. селектор в UI).
# По умолчанию используется reasoning-модель grok-4.20-0309-reasoning.
# ⚠ Reasoning-модели x.ai НЕ поддерживают response_format=json_object — JSON-strict
#   гарантируется только инструкцией в system-промпте. Адаптер это знает
#   (см. _isReasoningModel в backend/src/services/llm/grok.adapter.js) и
#   автоматически отключает json_object для имён, содержащих «reasoning» / «thinking» / «-r1».
# ⚠ Если у вашего ключа нет доступа к этой модели — поменяйте на grok-4 / grok-4-fast.
#   Список доступных моделей покажет: docker exec seo_worker node scripts/check-proxy.js
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-4.20-0309-reasoning
# XAI_BASE_URL=https://api.x.ai/v1   # необязательно, по умолчанию официальный endpoint

# ── DashScope (Alibaba Model Studio) — вкладка «Сформировать JSON» / ACF ──
# Используется backend-прокси /api/acf-json/dashscope (см.
# backend/src/routes/acfJson.routes.js + backend/src/services/llm/dashscope.adapter.js),
# чтобы запрос к https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# шёл с СЕРВЕРА (а не из браузера клиента) и API-ключ Alibaba никогда
# не попадал в исходники фронт-бандла / DevTools.
#
# ⚠ DASHSCOPE_API_KEY читается ТОЛЬКО отсюда (.env). Хардкод в коде
#   запрещён — Alibaba/GitHub Secret Scanning отзывают опубликованные ключи.
#   .env гитайгнорится (см. .gitignore). В docker-compose ключ подхватывается
#   через env_file: .env.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.6-plus
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Опциональный прокси ИСКЛЮЧИТЕЛЬНО для DashScope (не наследуется
# от LLM_PROXY_*/HTTPS_PROXY — Qwen намеренно ходит независимо от
# Gemini/Grok, чтобы их прокси-сбои не валили вкладку «Сформировать JSON»):
# DASHSCOPE_PROXY_URL=http://user:pass@host:port

# ── Relevance Analyzer (вкладка «Релевантность» — XMLStock + BM25 + n-граммы) ──
# Python-микросервис `relevance` (FastAPI + readability-lxml + pymorphy3 + rank-bm25)
# поднимается отдельным контейнером в docker-compose. Наружу не торчит,
# Node-бэкенд ходит на http://relevance:8000 во внутренней сети Docker.
#
# RELEVANCE_INTERNAL_TOKEN — общий секрет: backend кладёт его в заголовок
# X-Internal-Token, Python-сервис сверяет. Если оставить пустым — auth-проверка
# отключена (dev mode). В прод-окружении ОБЯЗАТЕЛЬНО задать одинаковое значение
# на обеих сторонах (docker-compose прокидывает переменную в оба контейнера).
RELEVANCE_INTERNAL_URL=http://relevance:8000
RELEVANCE_INTERNAL_TOKEN=
# Опциональные тюнинги пайплайна (значения по умолчанию работают для прода):
# RELEVANCE_FETCH_TIMEOUT_MS=15000     — per-URL HTTP timeout
# RELEVANCE_FETCH_CONCURRENCY=6        — параллельные fetch-запросы (1..20)
# RELEVANCE_MAX_HTML_BYTES=4194304     — лимит на 1 страницу (4 MB)
# RELEVANCE_MIN_FETCHED=5              — минимум скачанных страниц для анализа
# RELEVANCE_ANALYZE_TIMEOUT_MS=240000  — таймаут вызова Python-микросервиса
# RELEVANCE_LOG_LEVEL=INFO             — log level Python-сервиса (DEBUG/INFO/WARN)

# ── Relevance: PR 2 — семантические коконы (SVD) и кэш сырых документов ──
# После /analyze processed_documents (леммы + POS-последовательности)
# складываются в Redis с TTL по ключу `relevance:raw:v1:{report_id}`,
# чтобы можно было повторно запустить расчёт коконов без перепарсинга
# ТОП-20. Сами тексты страниц нигде не хранятся.
#
# Используется тот же REDIS_URL/REDIS_HOST/REDIS_PORT/REDIS_PASSWORD,
# что и для responseCache/sseManager. Если Redis недоступен — фича PR 2
# просто отключается (graceful degradation), пайплайн PR 1 не падает.
#
# RELEVANCE_RAW_TTL_SECONDS=604800     — TTL processed-документов (7 дней)
# RELEVANCE_RAW_MAX_BYTES=16777216     — max размер JSON в Redis (16 MiB)
# RELEVANCE_COCOONS_N_TOPICS=8         — default число LSI-тем (можно
#                                        переопределять в POST .../cocoons body)
# RELEVANCE_COCOONS_TOP_TERMS=12       — топ-N лемм на тему

# ── Relevance: PR 3 — починка парсинга + сравнение «наш сайт vs ТОП» ─────
# Парсер мигрирован на trafilatura (industry-standard, f1~0.92 vs ~0.70 у
# readability-lxml на русском). Логика двухуровневая: сначала heavy-tags
# (p/h*/li/article/main), и только если их < HEAVY_TAGS_MIN_CHARS —
# расширяем зону до div/span. Это закрывает регресс PR #90, когда сайты
# с обильным <div>-layout'ом (меню, фильтры) набирали > 800 символов
# навигационного мусора и fallback на readability никогда не запускался.
#
# RELEVANCE_HEAVY_TAGS_MIN_CHARS=800   — порог достаточности «жирных» тегов
# RELEVANCE_MIN_BODY_TEXT_CHARS=800    — порог запуска wide-fallback (div/span)
# RELEVANCE_LINK_DENSITY_NOISE_RATIO=0.6
#                                       — доля ссылок в блоке, при которой
#                                         он считается boilerplate'ом
#                                         (Mozilla Readability heuristic)
#
# ── Аггрегаторы (Avito, hh, ozon, dzen, …) ───────────────────────────────
# Чекбокс «Исключить агрегаторы» на форме отчёта режет их ДО парсинга,
# чтобы не размывать словарь корпуса. Базовый список зашит в
# backend/src/services/relevance/aggregatorDomains.js, расширяется через:
#
# RELEVANCE_AGGREGATOR_DOMAINS=domain1.ru,domain2.com
#                                       — доп. домены через запятую/перенос
#
# ── Cookie-jar / WAF / SPA ───────────────────────────────────────────────
# pageFetcher держит per-URL cookie jar (tough-cookie + axios-cookiejar-
# support) — это ловит Cloudflare cf_clearance / Qrator-челленджи.
# Если оба axios-захода дали < N байт текста — пробуем headless-fallback
# через внешний сервис (POST {url, timeout_ms} → {html}). Тяжёлый
# Chromium в основном backend НЕ запускаем — поднимайте отдельным
# контейнером (Playwright) и указывайте его URL ниже.
#
# RELEVANCE_HEADLESS_FETCHER_URL=http://relevance_fetcher:8001/fetch
#                                       — URL внешнего headless-сервиса
#                                         (по умолчанию compose поднимает
#                                         собственный сервис relevance_fetcher
#                                         на этом адресе, отдельно настраивать
#                                         не нужно).
# RELEVANCE_HEADLESS_TIMEOUT_MS=35000  — таймаут одного headless-вызова
# RELEVANCE_SPA_THRESHOLD_BYTES=1500   — ниже — считать страницу SPA
#                                        и звать headless (если задан).
# RELEVANCE_FETCHER_DEFAULT_TIMEOUT_MS=35000   — дефолтный timeout сервиса
# RELEVANCE_FETCHER_MAX_TIMEOUT_MS=60000        — потолок timeout сервиса
# RELEVANCE_FETCHER_LOG_LEVEL=INFO              — логи relevance_fetcher

# ── Relevance: anti-bot — ротация прокси и backoff ───────────────────────
# pageFetcher ротирует пул свежих браузерных User-Agent на каждый URL и
# поддерживает прокси-ротатор (обход IP-блокировок/гео). Прокси применяется
# автоматически, если задан пул ниже; per-запрос можно выключить флагом
# proxies_enabled=false. Туннелирование — через https-proxy-agent (CONNECT).
#
# RELEVANCE_PROXY_URL=******host:port — один прокси
# RELEVANCE_PROXY_LIST=http://h1:port,http://h2:port  — пул (ротатор), через
#                                       запятую/перенос строки
# RELEVANCE_FETCHER_PROXY=******host:port — дефолтный прокси
#                                       для headless-сервиса relevance_fetcher
#                                       (Playwright launch с proxy)
# RELEVANCE_RETRY_BASE_DELAY_MS=600    — базовая пауза экспоненциального
#                                       backoff между ретраями (429/5xx/timeout)
# RELEVANCE_RETRY_MAX_DELAY_MS=8000    — потолок паузы backoff

# ── Relevance: Wave 1 — конкурентные сигналы из утечек Google/Yandex ─────
# Включает per-URL извлечение Wave-1 сигналов в отчёте /analyze:
#   • title / H1 / meta-шаблон + точные вхождения query;
#   • schema.org-профиль (JSON-LD/microdata/RDFa);
#   • freshness (datePublished/dateModified из множества источников);
#   • URL/slug-факторы;
#   • trust-link density (внешние ссылки на .gov/.edu/Wikipedia/ГОСТ/СМИ);
#   • banker внутренних анкоров (brand/exact/partial/generic + diversity);
#   • UX-профиль (ToC, above-the-fold, headings/1k-words, FAQ/TL;DR-маркеры);
#   • exact-form occurrences (Yandex FI_BCLM_*: первые 100/200/300 слов, H2,
#     alt) — позиционные метрики;
#   • host-hygiene (canonical/hreflang/OG/TwitterCards/sitemap/Я.Метрика/GA).
# По умолчанию ВКЛЮЧЕНО (легковесно, без ML и сети). Выключатель:
#
# RELEVANCE_COMPETITOR_SIGNALS=false  — отключить блок целиком (тогда
#                                       /analyze не вернёт competitor_signals
#                                       даже при include_competitor_signals=true).
#
# ── Wave 2 / Wave 3 — расширенные сигналы ────────────────────────────────
# Wave 2 (включена ПО УМОЛЧАНИЮ вместе с competitor_signals; CPU-only):
#   • SERP-intent классификатор (info / commercial / transactional /
#     navigational) + чеклист обязательных коммерческих блоков;
#   • format классификатор (guide / listicle / comparison / qa /
#     case_study / glossary / product_page / hub_page) + рекомендованная
#     H2-канва по DF;
#   • mandatory_questions — банк вопросов с DF≥2 в топе (без PAA);
#   • lite-NER + entity_coverage (regex-кандидаты Заглавная Заглавная +
#     латинские акронимы; полный Natasha-NER гейтится отдельно — см. ниже);
#   • headings-only n-grams (би/три ТОЛЬКО из H2/H3, отдельно от body).
#
# Wave 3 (опционально, ML / тяжёлые сигналы):
#   • TTR + MTLD (лексическое разнообразие) — pure CPU, без модели.
#     Включено всегда, добавлено как +10 баллов в effort_score.
#   • title-pattern miner (listicle / question / comparison / brand_pipe /
#     brackets / year_present) — pure regex, всегда включено.
#   • topical_distance + page_radius на эмбеддингах — гейт ниже.
#
# RELEVANCE_NER_FULL=false             — включить полный Natasha-NER вместо
#                                        regex-фолбэка. Требует:
#                                          pip install natasha
#                                        Замедляет /analyze примерно в 3–5×.
#                                        Если pkg не установлен — gracefully
#                                        fallback на regex (без ошибок).
#
# RELEVANCE_EMBEDDINGS=false           — включить вычисление topical_distance
#                                        (cosine our↔centroid + pairwise топа)
#                                        и page_radius на sentence-transformers.
#                                        Требует:
#                                          pip install sentence-transformers
#                                        Модель ~120 МБ, грузится при первом
#                                        запросе. Если pkg не установлен —
#                                        вернёт {enabled: false, reason: …}
#                                        и UI покажет «ML не активирован».
#
# RELEVANCE_EMBEDDINGS_MODEL=paraphrase-multilingual-MiniLM-L12-v2
#                                       — переопределить модель эмбеддингов
#                                        (только если RELEVANCE_EMBEDDINGS=true).

# ── Proxy (ОБЯЗАТЕЛЬНО для Gemini И Grok из России) ───────────────────────
#
# ⚠ ВАЖНО: достаточно настроить ОДИН прокси на оба провайдера.
#   Адаптер Grok сам подхватит GEMINI_PROXY_* (или общие LLM_PROXY_*),
#   если отдельные XAI_PROXY_* не заданы. Порядок резолвинга:
#     1) XAI_PROXY_*   (только если хотите разный прокси для x.ai)
#     2) LLM_PROXY_*   (общий канал для всех LLM — рекомендуется)
#     3) GEMINI_PROXY_* (fallback — тот же прокси, что и для Gemini)
#     4) HTTPS_PROXY    (системный)
#   Без прокси оба адаптера бросают ошибку на старте запроса (никаких «прямых» вызовов).
#
#
# ⚠ БЕЗ ПРОКСИ GEMINI API НЕ БУДЕТ РАБОТАТЬ!
#
# ─── Рекомендуемый способ (компоненты — работает всегда): ─────────────────
# Используйте отдельные переменные — они не ломаются от спецсимволов в пароле.
#
GEMINI_PROXY_HOST=your_proxy_ip
GEMINI_PROXY_PORT=your_proxy_port
GEMINI_PROXY_USER=your_proxy_login
GEMINI_PROXY_PASS=your_proxy_password
# GEMINI_PROXY_PROTO=http
#
# ─── Альтернатива (полная строка — требует правильное экранирование): ─────
# ⚠ Если в пароле есть спецсимволы (#, $, @, !, пробелы) — обязательно
#    оберните ВСЮ строку в двойные кавычки:
#
# GEMINI_PROXY_URL="http://login:password@ip:port"
#
# Также поддерживаются форматы провайдеров (авто-конвертация):
# GEMINI_PROXY_URL="login:password:ip:port"
# GEMINI_PROXY_URL="http://login:password:ip:port"
#
# ─── Запасной прокси (авто-переключение при гео-блокировке): ──────────────
# GEMINI_PROXY_HOST_2=backup_proxy_ip
# GEMINI_PROXY_PORT_2=backup_proxy_port
# GEMINI_PROXY_USER_2=backup_proxy_login
# GEMINI_PROXY_PASS_2=backup_proxy_password
#
# ─── Прокси для Grok (x.ai) ──────────────────────────────────────────────
# Приоритет резолвинга в grok.adapter.js:
#   1) XAI_PROXY_*   — специфично для Grok
#   2) LLM_PROXY_*   — общий для всех LLM (рекомендуется при одном провайдере прокси)
#   3) GEMINI_PROXY_* — fallback (тот же канал, что у Gemini)
#   4) HTTPS_PROXY    — системный
# Без прокси grok.adapter бросит ошибку (как и Gemini).
#
# XAI_PROXY_HOST=your_proxy_ip
# XAI_PROXY_PORT=your_proxy_port
# XAI_PROXY_USER=your_proxy_login
# XAI_PROXY_PASS=your_proxy_password
# XAI_PROXY_URL="http://login:password@ip:port"   # альтернатива
#
# ─── Общий LLM_PROXY_* (если хотите один источник на всех провайдеров) ───
# LLM_PROXY_HOST=your_proxy_ip
# LLM_PROXY_PORT=your_proxy_port
# LLM_PROXY_USER=your_proxy_login
# LLM_PROXY_PASS=your_proxy_password
#
# ─── Проверка прокси из контейнера: ──────────────────────────────────────
#   docker exec seo_worker node scripts/check-proxy.js
# ─────────────────────────────────────────────────────────────────────────

# ── Rate limits (можно переопределить, дефолты работают для прода) ────────
# AUTH_LOGIN_RATE_LIMIT=10        # попыток логина за 15 мин на IP (skip успешных)
# AUTH_REGISTER_RATE_LIMIT=5      # регистраций за 1 час на IP
#  /api/tasks/:id/logs — 120/мин per-IP (захардкожен; влияет только на админ-страницы
#  и переподключения к мониторингу — фронт читает /logs один раз при mount).

# ── Redis-кэш ответа LLM (опционально) ─────────────────────────────────────
# Детерминированный кэш по ключу sha256(adapter+model+system+user+temperature+maxTokens).
# Помогает, когда юзер пересоздаёт ту же задачу с теми же входами — экономит деньги.
# LLM_RESPONSE_CACHE_ENABLED=false
# LLM_RESPONSE_CACHE_TTL_SECONDS=604800   # 7 дней по умолчанию

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
# ⚠ JWT_SECRET — ОБЯЗАТЕЛЬНО задайте уникальное значение!
# Если не задан, система будет работать со встроенным fallback-секретом,
# но для безопасности в продакшне рекомендуется задать свой.
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Docker Compose ────────────────────────────────────────────────────────
# ⚠ ВАЖНО: POSTGRES_USER и POSTGRES_DB используются как для создания БД,
#   так и для формирования DATABASE_URL внутри docker-compose.yml.
#   Если вы меняете эти значения ПОСЛЕ первого запуска, нужно удалить
#   volume базы данных: docker compose down -v && docker compose up -d --build
#   Иначе PostgreSQL выдаст ошибку: Role "..." does not exist.
POSTGRES_DB=seogenius_db
POSTGRES_USER=seogenius
POSTGRES_PASSWORD=your_password

# ── Admin Panel ────────────────────────────────────────────────────────────
# Администратор создаётся/обновляется автоматически при каждом запуске.
# Если вы измените email или пароль — просто перезапустите сервер.
# По умолчанию (если не задано): targetlid1@yandex.ru / 1324354657Cfif
ADMIN_EMAIL=targetlid1@yandex.ru
ADMIN_PASSWORD=1324354657Cfif

# ── Link Article Generator (ссылочная статья для sape/miralinks/gogetlinks) ──
# Изолированный пайплайн: своя таблица link_article_tasks, свои промты
# (backend/src/prompts/linkArticle/*.txt), основной SEO-пайплайн не трогается.
#
# Модель Gemini для написания статьи. По умолчанию берётся общая GEMINI_MODEL;
# переопределить можно здесь — например, если хотите использовать flash-модель
# для black-list ссылочных площадок, а основную генерацию оставить на pro.
# LINK_ARTICLE_GEMINI_MODEL=gemini-3.1-pro-preview
#
# Модель Nano Banana Pro для изображений (multimodal Gemini Image-preview).
# Если у вашего API-ключа нет доступа — задача завершится с ошибкой на image-шаге,
# но текст статьи (без изображений) всё равно сохранится в БД.
# LINK_ARTICLE_IMAGE_MODEL=gemini-3-pro-image-preview
#
# Ориентировочная стоимость одного сгенерированного изображения в USD
# (используется только для учёта в cost_usd, на реальный биллинг не влияет).
# Дефолт 0.12 — реальный тариф Nano Banana Pro (gemini-3-pro-image-preview)
# на апрель 2026. Старая константа 0.04 занижала расход примерно в 3 раза.
# NANO_BANANA_PRO_PRICE_USD имеет приоритет; GEMINI_IMAGE_PRICE_USD оставлен
# как legacy fallback для обратной совместимости — задавайте только одно из.
# NANO_BANANA_PRO_PRICE_USD=0.12
# GEMINI_IMAGE_PRICE_USD=0.04
#
# Параллелизм image-генерации (1–5). По умолчанию 3 — как раз на 3 слота статьи.
# LINK_ARTICLE_MAX_PARALLEL_IMAGES=3
#
# Дополнительный прокси для image-модели (если отличается от основного Gemini).
# Не задан → используется LLM_PROXY_* → GEMINI_PROXY_* (включая запасные слоты
# GEMINI_PROXY_URL_2 … _5 и провайдер-формат "login:password:ip:port", который
# нормализуется так же, как в текстовом адаптере) → HTTPS_PROXY. Этой же цепочкой
# пользуется генерация обложки в «Статье в блог» (info-article — 1 картинка).

# ── LLM Concurrency Limits (rate-limiter, per worker process) ──────────────
# Per-provider семафор в backend/src/services/llm/rateLimiter.js. Защищает API-
# ключи DeepSeek / Gemini / Grok от каскадных 429/503 при параллельной обработке
# 50–100 задач. Лимиты ОТНОСЯТСЯ к одному воркеру: при WORKER_CONCURRENCY=3 и
# DEEPSEEK_MAX_CONCURRENT=8 теоретически на одной машине максимум 8 одновременных
# запросов к DeepSeek (так как все 3 BullMQ-job'а делят один process-wide пул).
# Установка значения 0 отключает throttling для провайдера.
#
# Дефолты подобраны под платные Tier-1 ключи:
# DEEPSEEK_MAX_CONCURRENT=8
# GEMINI_MAX_CONCURRENT=6
# XAI_MAX_CONCURRENT=4
#
# Если слот ждали дольше LLM_QUEUE_WARN_MS — печатаем console.warn с диагностикой
# (active/limit/queued). Помогает обнаружить bottleneck до того, как он станет
# проблемой пользователя. 0 — выключает предупреждения.
# LLM_QUEUE_WARN_MS=5000
# LINK_ARTICLE_IMAGE_PROXY_URL="http://login:password@ip:port"

# ── Info Article Generator — «Статья в блог» (POST /api/info-article) ──────
# Изолированный пайплайн информационной статьи на основе Excel'я с
# коммерческими страницами. Своя таблица info_article_tasks, свои промты
# (backend/src/prompts/infoArticle/*.txt), движок сам выбирает 1–2 ссылки
# на каждый <h2> и пишет статью.
#
# Модели (если не заданы — fallback на общие GEMINI_MODEL / DEEPSEEK_MODEL):
# INFO_ARTICLE_GEMINI_MODEL=gemini-3.1-pro-preview
# INFO_ARTICLE_DEEPSEEK_MODEL=deepseek-chat
# INFO_ARTICLE_IMAGE_MODEL=gemini-3-pro-image-preview
#
# Кэш Gemini cachedContents (TTL 900 с по умолчанию). Включается явно — не
# все аккаунты имеют квоту на cachedContents.
# INFO_ARTICLE_GEMINI_CACHE_ENABLED=false
# INFO_ARTICLE_GEMINI_CACHE_TTL_S=900
#
# Пороги качества (если не заданы — берём общие EEAT_PQ_TARGET=7.5 и
# LSI_COVERAGE_TARGET=80 из utils/objectiveMetrics.js).
# INFO_ARTICLE_EEAT_TARGET=7.5
# INFO_ARTICLE_LSI_TARGET=80
#
# Параметры семантической перелинковки.
# INFO_ARTICLE_MAX_LINKS_PER_H2=2
# INFO_ARTICLE_MIN_LINKS_PER_H2=1
# INFO_ARTICLE_MAX_REPEATS_PER_URL=2
# INFO_ARTICLE_MIN_SEMANTIC_SCORE=0.18
# INFO_ARTICLE_MAX_COMMERCIAL_LINKS=200
# Глобальный коридор: суммарно ссылок на статью (приоритетнее per-H2 лимитов).
# По умолчанию используется ДИНАМИКА «1 ссылка на 2500 символов»:
#   target = round(estimatedChars / INFO_ARTICLE_CHARS_PER_LINK),
#   estimatedChars = Σ outline.sections.recommended_word_count × 6 (русский).
#   Границы [2..12] + физический cap H2_count × MAX_LINKS_PER_H2.
# INFO_ARTICLE_CHARS_PER_LINK=2500
# Если ОБА TOTAL_MIN/TOTAL_MAX заданы — используется фикс-коридор (legacy):
# INFO_ARTICLE_TOTAL_MIN_LINKS=3
# INFO_ARTICLE_TOTAL_MAX_LINKS=4
#
# Параллелизм изображений (как в link-article).
# INFO_ARTICLE_MAX_PARALLEL_IMAGES=3

# ── SERP-evidence grounding (Phase 1 / P0-2) ──────────────────────────
# Перед написанием статьи скачиваем top SERP по теме (Yandex через
# XMLStock), парсим HTML тем же relevance-микросервисом и вытаскиваем
# top-K BM25-параграфов на каждый URL. Результат идёт в user-prompt
# Stage 3 как блок [SERP_EVIDENCE], чтобы Gemini опирался на реальный
# текст конкурентов, а не на параметрику модели. Также используется
# (в будущих PR) для P0-1 fact-check и P0-3 антиплагиата.
#
# По умолчанию ВЫКЛЮЧЕНО — фундамент укладывается без изменения
# дефолтного поведения. Включить локально/на стейдже:
# INFO_ARTICLE_GROUNDING_ENABLED=true
#
# Параметры:
# INFO_ARTICLE_GROUNDING_TOP_N=5            # сколько URL из SERP скачивать (1..20)
# INFO_ARTICLE_GROUNDING_TOP_K=5            # сколько top-абзацев на URL (1..20)
# INFO_ARTICLE_GROUNDING_MAX_CHARS_PER_URL=1500  # квота символов сниппетов на URL
# INFO_ARTICLE_GROUNDING_CACHE_TTL_S=3600   # in-memory кэш результата (по query+lr)
# INFO_ARTICLE_GROUNDING_CACHE_MAX=64       # макс число записей в LRU-кэше

# ── Fact-check verifier (Phase 1 / P0-1) ──────────────────────────────
# После того как writer сгенерировал финальный HTML, прогоняем его через
# детерминированный экстрактор «фактологических утверждений» (числа, %,
# годы, валюты, единицы измерения) и сверяем каждое с собранными выше
# SERP-evidence сниппетами. Цель — поймать «галлюцинированные» цифры,
# которых нет ни в одном источнике из топа выдачи.
#
# Без LLM, без сети, в памяти; результат сохраняется в info_article_tasks
# .fact_check_report (JSONB) и кратко логгируется в task_logs.
#
# Требует, чтобы был включён INFO_ARTICLE_GROUNDING_ENABLED — без evidence
# нечего сверять, fact-check автоматически skip'ается.
#
# По умолчанию ВЫКЛЮЧЕНО.
# INFO_ARTICLE_FACTCHECK_ENABLED=true

# ── Anti-plagiarism (Phase 1 / P0-3) ──────────────────────────────────
# Детерминированная сверка финального HTML с теми же SERP-evidence
# сниппетами по n-gram overlap (greedy жадное расширение совпадений).
# Цель — поймать прямые дословные заимствования у конкурентов, особенно
# при включённом grounding'е, когда LLM может «срисовать» абзац из
# предоставленного контекста вместо рерайта.
#
# Per-sentence verdict:
#   clean       — overlap < INFO_ARTICLE_PLAGIARISM_SUSPICIOUS_PCT
#   suspicious  — overlap ≥ INFO_ARTICLE_PLAGIARISM_SUSPICIOUS_PCT (default 0.30)
#   plagiarism  — overlap ≥ INFO_ARTICLE_PLAGIARISM_FAIL_PCT       (default 0.60)
#
# Article-level verdict:
#   pass    — нет plagiarism, overlap_total < 10%
#   review  — 1 plagiarism ИЛИ 10% ≤ overlap_total < 20% ИЛИ >3 suspicious
#   fail    — иначе
#
# Без LLM, без сети, в памяти; результат сохраняется в info_article_tasks
# .plagiarism_report (JSONB) и кратко логгируется в task_logs.
#
# Требует, чтобы был включён INFO_ARTICLE_GROUNDING_ENABLED — без evidence
# нечем сверять, plagiarism-check автоматически skip'ается.
#
# По умолчанию ВЫКЛЮЧЕНО.
# INFO_ARTICLE_PLAGIARISM_ENABLED=true
# INFO_ARTICLE_PLAGIARISM_NGRAM=5             # размер скользящего n-gram (3..10)
# INFO_ARTICLE_PLAGIARISM_SUSPICIOUS_PCT=0.30 # порог suspicious per-sentence
# INFO_ARTICLE_PLAGIARISM_FAIL_PCT=0.60       # порог plagiarism per-sentence

# ── Image QA — Phase 1 / P0-4 ─────────────────────────────────────────
# Детерминированный пост-аудит сгенерированных изображений (cover + inline):
# валидность base64, формат через magic-bytes (PNG/JPEG/WebP/GIF), размеры,
# аспект, sha256-дубли, пустые alt_ru. Не делает сетевых запросов и не
# вызывает LLM. Никогда не валит pipeline — только пишет отчёт в
# info_article_tasks.image_qa_report и краткую сводку в task_logs.
#
# Verdict:
#   pass   — нет ошибок, нет дублей
#   review — есть warnings (cover не landscape, пустой alt, дубль inline)
#   fail   — есть hard-error (битый base64, формат не распознан, мелкая
#            картинка/файл, AR вне диапазона, дубль cover) ИЛИ cover (slot=1)
#            отсутствует/error
#   na     — изображения не запрошены / ничего не отрендерилось
#
# По умолчанию ON (безопасный чек). Отключить:
# INFO_ARTICLE_IMAGE_QA_ENABLED=false
#
# Пороги (необязательны, разумные дефолты):
# INFO_ARTICLE_IMAGE_QA_MIN_BYTES=5120        # < 5 KB → битая/пустая (default 5120)
# INFO_ARTICLE_IMAGE_QA_MAX_BYTES=8388608     # > 8 MB → перегружает БД/SSE
# INFO_ARTICLE_IMAGE_QA_MIN_DIM=512           # минимальная сторона в px
# INFO_ARTICLE_IMAGE_QA_COVER_MIN_AR=1.2      # AR cover'а должен быть ≥ (горизонталь)
#
# Что НЕ проверяется (out of scope без vision-модели):
# водяные знаки, логотипы, корректность сюжета, эстетика. Это
# намеренно: image-QA — детерминированный гейт, а не «глаз дизайнера».

# ── Module Context (Module 1+2) — pure-derive поверх Stage 0/1/2 ──────
# Деривация без LLM-вызовов. Лимиты на размер contractа можно
# переопределить (по умолчанию подобраны так, чтобы §11 в AKB укладывался
# в ~1.5–2 КБ и не раздувал Gemini-токены):
# MODULE_CTX_MAX_ENTITIES=25
# MODULE_CTX_MAX_AVOID=15
# MODULE_CTX_MAX_LANG=12
# MODULE_CTX_MAX_CLAIMS=15
# MODULE_CTX_MAX_JTBD=15
#
# ── Stage 8 Quality Evaluator (опц., LLM-as-judge) ────────────────────
# По умолчанию ВЫКЛЮЧЕН — нулевое влияние на текущий пайплайн.
# Включай для сбора объективных метрик качества (например, перед DSPy/MIPROv2
# оптимизацией). Один DeepSeek-вызов после Stage 7, ~$0.001 за задачу.
# Промт построен на основе backend/src/prompts/source/19-Regulatory & Risk Scanner.txt
# и проверяет: покрытие mandatory_entities, нарушения avoid_ambiguous_terms,
# подтверждение claims_to_prove, регуляторные риски, total_score 0..10.
# Отчёт сохраняется в tasks.evaluator_report (миграция 014) и публикуется
# как SSE-событие 'evaluator_report'.
# STAGE8_EVALUATOR_ENABLED=false
# STAGE8_TEXT_CAP=12000   # сколько символов очищенного текста статьи отдаём evaluator'у

# ── Article Topics — Quality Evaluator (опц., LLM-as-judge) ───────────
# По умолчанию ВЫКЛЮЧЕН — нулевое влияние на текущий пайплайн и стоимость.
# Один DeepSeek-вызов после успешного main / deep-dive прогона, ~$0.001/задача.
# Оценивает foresight-отчёт по 5 критериям (specificity / evidence /
# actionability / novelty / structure_compliance, 0..10 каждый).
# Отчёт сохраняется в article_topic_tasks.evaluator_report (миграция 016)
# и отображается как ⭐-рейтинг в карточке задачи (фронт).
# ARTICLE_TOPICS_EVALUATOR_ENABLED=false
# ARTICLE_TOPICS_EVALUATOR_TEXT_CAP=12000   # ограничение длины markdown, отдаваемого судье

# ── Article Topics — Idea-mode (Подбор тем статей) ────────────────────
# Третий режим раздела «Темы статей»: один Gemini-вызов проводит анализ
# рынка/сущностей/интентов и предлагает ровно N тем для блога с описанием
# ЦА и фактов о бренде. Гейт включён по умолчанию (фича безопасна), потолок
# topic_count = 30 (выше — Gemini не успевает в 16k output-токенов).
# ARTICLE_TOPICS_TOPIC_IDEAS_ENABLED=true
# ARTICLE_TOPICS_TOPIC_IDEAS_MAX=30
# ─────────────────────────────────────────────────────────────────────────────
# A.E.G.I.S. («Эгида») — мозг системы
# Все флаги по умолчанию ВЫКЛЮЧЕНЫ: подключение A.E.G.I.S. не меняет
# поведение существующих 9 модулей. Подробная инструкция: AEGIS_SETUP.md.
# ─────────────────────────────────────────────────────────────────────────────

# Глобальный kill-switch
# AEGIS_ENABLED=false

# ── Жёсткий гейт качества (по решению владельца: Spq ≥ 8.0 = overall ≥ 80) ─
# AEGIS_QUALITY_MIN_OVERALL=80      # ≥ 80 по шкале 0..100 = ≥ 8.0 по шкале 0..10
# AEGIS_QUALITY_MIN_EEAT=70
# AEGIS_QUALITY_MIN_FACTCHECK=70
# AEGIS_QUALITY_MIN_PLAGIARISM=70
# AEGIS_QUALITY_ON_FAIL=fail        # fail | review

# ── Шеннон-фильтр мусорного контента (Stage 0) ──────────────────────────────
# AEGIS_SHANNON_ENABLED=false
# AEGIS_SHANNON_MIN_ENTROPY=3.5     # отбрасываем тексты с H < 3.5 бит/символ
# AEGIS_SHANNON_MIN_LENGTH=80

# ── Бюджеты на одну задачу (защита от галлюцинаторного цикла) ──────────────
# AEGIS_GEMINI_TASK_TOKENS=2000000
# AEGIS_DEEPSEEK_TASK_USD=5
# AEGIS_OVERALL_TASK_USD=8

# ── Python-сервис aegis_py (GraphRAG / VectorDB / Ray / DSPy / GA4 / Mutator)
# AEGIS_PY_URL=http://localhost:8800

# ── Phase 1: GraphRAG (Neo4j + NetworkX) ─────────────────────────────────────
# AEGIS_GRAPHRAG_ENABLED=false
# AEGIS_NEO4J_URI=bolt://localhost:7687
# AEGIS_NEO4J_USER=neo4j
# AEGIS_NEO4J_PASSWORD=
# AEGIS_GRAPHRAG_TOP_K=12
# AEGIS_GRAPHRAG_CACHE_TTL_SEC=3600
# AEGIS_GRAPHRAG_TIMEOUT_MS=15000

# ── Phase 2: VectorDB (Qdrant, hybrid dense+sparse, эмбеддинги от Gemini) ──
# AEGIS_VECTORDB_ENABLED=false
# AEGIS_QDRANT_URL=http://localhost:6333
# AEGIS_QDRANT_API_KEY=
# AEGIS_EMBEDDER=gemini             # gemini | openai | local-bge
# AEGIS_VECTORDB_HYBRID_ALPHA=0.5
# AEGIS_VECTORDB_TIMEOUT_MS=15000

# ── Phase 4: Ray Cluster (150+ параллельных actors) ─────────────────────────
# AEGIS_RAY_ENABLED=false
# AEGIS_RAY_URL=ray://localhost:6379
# AEGIS_RAY_MAX_CONCURRENT=150
# AEGIS_RAY_TIMEOUT_MS=30000

# ── Phase 5: LangGraph оркестратор (writer→critic→refiner loop) ─────────────
# AEGIS_LANGGRAPH_ENABLED=false
# AEGIS_LANGGRAPH_MAX_REFINE=3      # сколько итераций refine'а до отбраковки
# AEGIS_LANGGRAPH_TARGET_OVERALL=80 # целевой Spq на каждой итерации

# ── Phase 6: DSPy MIPROv2 эволюционный контур ───────────────────────────────
# AEGIS_DSPY_ENABLED=false
# AEGIS_DSPY_MAX_TRIALS=20
# AEGIS_DSPY_MAX_COST_USD=50
# AEGIS_DSPY_MIN_IMPROVEMENT_PCT=5  # ниже — не перезаписываем brain_state

# ── Phase 7: RL / GA4 feedback loop (PPO-веса по CTR/engagement) ───────────
# AEGIS_RL_GA4_ENABLED=false
# AEGIS_GA4_PROPERTY_ID=
# AEGIS_GA4_SA_JSON=                # JSON service account (inline) ИЛИ
                                    # GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# AEGIS_RL_TOP_QUANTILE=0.75
# AEGIS_RL_PPO_WEIGHT=3

# ── Self-mutation (DeepSeek-V4-Pro как программист, НЕ Claude) ─────────────
# AEGIS_SELFMUTATE_ENABLED=false
# AEGIS_SELFMUTATE_REQUIRE_HUMAN=true  # первая неделя — ВСЕГДА true (draft-PR)
# AEGIS_SELFMUTATE_FAIL_TRIGGER=5      # ≥ N подряд фейлов на домене → триггер

# ── GitHub-бэклог (Issue-driven autopilot) ──────────────────────────────────
# AEGIS_BACKLOG_ENABLED=false
# AEGIS_GITHUB_REPO=owner/name
# AEGIS_GITHUB_PAT=                   # PAT с правом repo
# AEGIS_BACKLOG_LABEL=aegis:ready

# ── Phase 9: Observability & FinOps ─────────────────────────────────────────
# Метрики экспонируются на GET /api/aegis/metrics (Prometheus text format).
# Внешний Prometheus/Grafana — ОПЦИОНАЛЬНЫ.
# AEGIS_TELEMETRY_ENABLED=true
# AEGIS_TELEMETRY_SERVICE=aegis
# AEGIS_OTLP_HTTP_URL=                # опц. OTLP collector (push every N сек)
# AEGIS_TELEMETRY_PUSH_INTERVAL_SEC=60

# ── Phase 9: Alerting & Kill Switch ─────────────────────────────────────────
# Если за rolling-window расход > rateUsdPerHour → алерт + опц. auto-kill.
# AEGIS_ALERTING_ENABLED=false
# AEGIS_ALERT_RATE_USD_PER_HOUR=50    # глобальный потолок $/час
# AEGIS_ALERT_WINDOW_SEC=600          # окно для измерения rolling rate
# AEGIS_ALERT_AUTO_KILL=false         # авто-engage kill switch при превышении
# AEGIS_ALERT_TG_TOKEN=               # Telegram bot token (опц.)
# AEGIS_ALERT_TG_CHAT=                # chat_id (опц.)
# AEGIS_ALERT_SLACK_URL=              # Slack webhook (опц.)
# AEGIS_ALERT_COOLDOWN_SEC=300        # минимум между однотипными алертами

# ── Phase 10: Context Compression (LLMLingua-style) ─────────────────────────
# Детерминированное extractive сжатие промптов при превышении targetTokens.
# AEGIS_COMPRESS_ENABLED=false
# AEGIS_COMPRESS_TARGET_TOKENS=24000
# AEGIS_COMPRESS_MIN_TOKENS=4000      # ниже — не сжимаем
# AEGIS_COMPRESS_KEEP_TOP_RATIO=0.4   # доля топ-IDF предложений, обязательно сохранить

# ── Phase 11: Backups (Qdrant snapshot + Neo4j dump → S3) ───────────────────
# Cron .github/workflows/aegis-nightly-backup.yml → POST /api/aegis/backup/run.
# AEGIS_BACKUP_ENABLED=false
# AEGIS_BACKUP_S3_BUCKET=
# AEGIS_BACKUP_S3_REGION=eu-central-1
# AEGIS_BACKUP_S3_PREFIX=aegis/backups
# AEGIS_BACKUP_RETAIN_DAYS=30
# AEGIS_BACKUP_LOCAL_DIR=/var/lib/aegis/backups

# ── Phase 12: LLM Routing & Circuit Breaker (Fallback) ──────────────────────
# При 429/502/timeout primary — переключение на резервную модель (vLLM/Llama3).
# AEGIS_ROUTING_ENABLED=false
# AEGIS_ROUTING_CRITIC_CHAIN=deepseek,gemini
# AEGIS_ROUTING_WRITER_CHAIN=gemini,deepseek
# AEGIS_VLLM_URL=                     # опц. локальная vLLM (OpenAI-compatible API)
# AEGIS_VLLM_MODEL=meta-llama/Llama-3-70B-Instruct
# AEGIS_CB_FAIL_THRESHOLD=5           # N подряд-фейлов → circuit OPEN
# AEGIS_CB_OPEN_SEC=60                # сколько держим OPEN до half-open пробников
# AEGIS_CB_HALF_OPEN_PROBES=2

# ── Phase 13: Data Poisoning Filter ─────────────────────────────────────────
# Фильтр перед записью в Qdrant: hidden text, keyword stuffing, инвиз-юникод,
# числовые выбросы. Detection всегда ON; on_fail = drop|mark.
# AEGIS_POISON_ENABLED=true
# AEGIS_POISON_HIDDEN_MAX_RATIO=0.05    # > 5% скрытого текста → блок
# AEGIS_POISON_NGRAM_MAX_REPEAT=8       # 3-gram повторов больше — стаффинг
# AEGIS_POISON_INVISIBLE_MAX_RATIO=0.01 # ZWSP/RLO и пр.
# AEGIS_POISON_NUMERIC_OUTLIER_X=5.0    # значение > 5× медианы → выброс
# AEGIS_POISON_ON_FAIL=drop             # drop | mark
